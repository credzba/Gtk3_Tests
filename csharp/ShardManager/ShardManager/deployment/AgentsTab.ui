<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.0"/>
  <object class="GtkWindow" id="wnd_agents_tab">
    <property name="visible">False</property>
    <property name="title">AgentsTab</property>
    <child>
  <!-- AgentsTab.ui — container; sub-tabs populated in code -->
  <object class="GtkBox" id="tab_root">
    <property name="visible">True</property>
    <property name="orientation">vertical</property>
    <child>
      <object class="GtkNotebook" id="agents_subnotebook">
        <property name="visible">True</property>
        <property name="show-tabs">True</property>
      </object>
      <packing>
        <property name="expand">True</property>
        <property name="fill">True</property>
      </packing>
    </child>
  </object>
    </child>
  </object>
</interface>
